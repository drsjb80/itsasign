{
  "plugins": [
    "./widgets/clock.js",
    "./widgets/weather.js",
    "./widgets/playlist.js"
  ],
  "rss": {
    "proxy": "http://localhost:8080/"
  },
  "layout": {
    "columns": "2fr 1fr",
    "rows": "1fr"
  },
  "panels": [
    {
      "title": "Main",
      "gridArea": "1 / 1 / 2 / 2",
      "widgets": [
        {
          "type": "playlist",
          "title": "Content Loop",
          "defaultImageDurationMs": 10000,
          "defaultRssItemsPerPage": 3,
          "defaultRssPageDurationMs": 7000,
          "defaultRssMaxItems": 12,
          "items": [
            {
              "type": "image",
              "title": "Toby",
              "src": "images/Toby.png",
              "durationMs": 8000,
              "fit": "cover"
            },
            {
              "type": "rss-feed",
              "title": "BBC News",
              "url": "https://feeds.bbci.co.uk/news/rss.xml",
              "itemsPerPage": 5,
              "pageDurationMs": 10000,
              "maxItems": -1,
              "showQr": true
            },
            {
              "type": "rss-feed",
              "title": "NYTimes Home",
              "url": "https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml",
              "itemsPerPage": 5,
              "pageDurationMs": 10000,
              "maxItems": -1,
              "showQr": true
            }
          ]
        }
      ]
    },
    {
      "title": "Sidebar",
      "gridArea": "1 / 2 / 2 / 3",
      "widgets": [
        {
          "type": "clock",
          "size": 200,
          "backgroundColor": "#333"
        },
        {
          "type": "weather",
          "title": "Weather",
          "latitude": 39.7392,
          "longitude": -104.9903,
          "units": "fahrenheit",
          "refreshMs": 600000
        }
      ]
    }
  ]
}

