{
  "headerEnabled": true,
  "reloadConfigMs": 3600000,
  "plugins": [
    "./widgets/clock.js",
    "./widgets/daydate.js",
    "./widgets/weather.js",
    "./widgets/playlist.js",
    "./widgets/moon.js",
    "./widgets/qotd.js",
    "./widgets/xkcd.js"
  ],
  "rss": {
    "proxy": "http://localhost:8080/",
    "itemDurationMs": 3000,
    "fontScale": 2,
    "showQR": true,
    "showThumbnails": true,
    "itemsPerPage": 4,
    "maxItems": -1
  },
  "images": {
    "durationMs": 10000,
    "fit": "cover"
  },
  "panels": [
    {
      "className": "header-strip",
      "widgets": [
        {
          "type": "playlist",
          "items": [
            {
              "type": "image",
              "title": "Header",
              "src": "images/CS_Largecopy.jpg",
              "durationMs": 0,
              "fit": "contain"
            }
          ]
        }
      ]
    },
    {
      "title": "Main",
      "className": "main-panel",
      "widgets": [
        {
          "type": "playlist",
          "title": "Content",
          "items": [
            {
              "type": "xkcd",
              "title": "XKCD",
              "durationMs": 10000
            },
            {
              "type": "image",
              "title": "Toby",
              "src": "http://sites.msudenver.edu/beatys/wp-content/uploads/sites/461/2026/04/Toby-scaled.png"
            },
            {
              "type": "rss-feed",
              "title": "AI",
              "url": "https://cacm.acm.org/category/artificial-intelligence-machine-learning/feed/"
            },
            {
              "type": "rss-feed",
              "title": "Computing and Society",
              "url": "https://cacm.acm.org/category/society/feed/"
            },
            {
              "type": "image",
              "title": "NOAA",
              "src": "https://www.wpc.ncep.noaa.gov/noaa/noaa.gif"
            },
            {
              "type": "rss-feed",
              "title": "SE and Languages",
              "url": "https://cacm.acm.org/category/software-engineering-and-programming-languages/feed/"
            },
            {
              "type": "rss-feed",
              "title": "Security and Privacy",
              "url": "https://cacm.acm.org/category/security-and-privacy/feed/"
            },
            {
              "type": "rss-feed",
              "title": "The Computing Profession",
              "url": "https://cacm.acm.org/category/computing-profession/feed/"
            }
          ]
        }
      ]
    },
    {
      "title": "Sidebar",
      "className": "sidebar-panel",
      "widgets": [
        {
          "type": "clock",
          "size": 200,
          "backgroundColor": "#333"
        },
        {
          "type": "daydate",
          "locale": "en-US"
        },
        {
          "type": "weather",
          "title": "Weather",
          "latitude": 39.7392,
          "longitude": -104.9903,
          "units": "fahrenheit",
          "useGeolocation": true,
          "geolocationTimeoutMs": 7000,
          "forecastDays": 5,
          "windSpeedUnit": "mph",
          "refreshMs": 600000
        },
        {
          "type": "moon",
          "title": "Moon",
          "refreshMs": 3600000
        },
        {
          "type": "qotd",
          "title": "Quote of the Day"
        }
      ]
    }
  ]
}

