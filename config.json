{
  "headerEnabled": true,
  "reloadConfigMs": 3600000,
  "plugins": [
    "./widgets/clock.js",
    "./widgets/daydate.js",
    "./widgets/weather.js",
    "./widgets/playlist.js",
    "./widgets/xkcd.js",
    "./widgets/moon.js",
    "./widgets/qotd.js"
  ],
  "rss": {
    "proxy": "http://localhost:8080/",
    "itemDurationMs": 2200,
    "fontScale": 2,
    "showQR": true,
    "showThumbnails": true,
    "itemsPerPage": 4,
    "maxItems": -1
  },
  "images": {
    "durationMs": 10000,
    "fit": "cover"
  },
  "layout": {
    "columns": "2fr 1fr",
    "rows": "160px 1fr"
  },
  "panels": [
    {
      "gridArea": "1 / 1 / 2 / 3",
      "className": "header-strip",
      "widgets": [
        {
          "type": "playlist",
          "items": [
            {
              "type": "image",
              "title": "Header",
              "src": "images/CS_Largecopy.jpg",
              "durationMs": 60000,
              "fit": "contain"
            }
          ]
        }
      ]
    },
    {
      "title": "Main",
      "gridArea": "2 / 1 / 3 / 2",
      "widgets": [
        {
          "type": "playlist",
          "title": "Content Loop",
          "items": [
            {
              "type": "image",
              "title": "Toby",
              "src": "https://www.wpc.ncep.noaa.gov/noaa/noaa.gif",
              "durationMs": 8000
            },
            {
              "type": "image",
              "title": "Toby",
              "src": "http://sites.msudenver.edu/beatys/wp-content/uploads/sites/461/2026/04/Toby-scaled.png",
              "durationMs": 8000
            },

            {
              "type": "rss-feed",
              "title": "BBC News",
              "url": "https://feeds.bbci.co.uk/news/rss.xml"
            },
            {
              "type": "rss-feed",
              "title": "ACM AI",
              "url": "https://cacm.acm.org/category/artificial-intelligence-machine-learning/feed/"
            }
          ]
        }
      ]
    },
    {
      "title": "Sidebar",
      "className": "sidebar-panel",
      "gridArea": "2 / 2 / 3 / 3",
      "widgets": [
        {
          "type": "clock",
          "size": 200,
          "backgroundColor": "#333"
        },
        {
          "type": "daydate",
          "locale": "en-US"
        },
        {
          "type": "weather",
          "title": "Weather",
          "latitude": 39.7392,
          "longitude": -104.9903,
          "units": "fahrenheit",
          "useGeolocation": true,
          "geolocationTimeoutMs": 7000,
          "forecastDays": 5,
          "windSpeedUnit": "mph",
          "refreshMs": 600000
        },
        {
          "type": "moon",
          "title": "Moon",
          "refreshMs": 3600000
        },
        {
          "type": "xkcd",
          "title": "XKCD",
          "refreshMs": 3600000
        },
        {
          "type": "qotd",
          "title": "Quote of the Day"
        }
      ]
    }
  ]
}

